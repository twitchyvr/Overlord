# ============================================================
# OVERLORD — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── AI Provider ─────────────────────────────────────────────
# MiniMax API key (required)
MINIMAX_API_KEY=your_minimax_api_key_here

# API base URL (default: MiniMax Anthropic-compatible endpoint)
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Model to use (MiniMax-M2.5-highspeed or MiniMax-M2.5)
ANTHROPIC_MODEL=MiniMax-M2.5-highspeed

# ── Image Understanding ──────────────────────────────────────
# Separate key for image API (optional — falls back to MINIMAX_API_KEY)
MINIMAX_IMG_API_KEY=

# ── Server ──────────────────────────────────────────────────
PORT=3031

# ── AI Behavior ─────────────────────────────────────────────
# Max output tokens per response
MAX_TOKENS=66000

# Temperature (0.0-1.0)
TEMPERATURE=0.7

# Thinking level 1-5 (1=minimal 512 tokens, 5=maximum 8192 tokens)
THINKING_LEVEL=3

# ── Request Limits ──────────────────────────────────────────
# Max AI→tool→AI cycles per user message (0 = unlimited)
MAX_AI_CYCLES=250

# Max AutoQA fix attempts per file
MAX_QA_ATTEMPTS=3

# Tool approval timeout in milliseconds (default: 5 minutes)
APPROVAL_TIMEOUT_MS=300000

# API request timeout in milliseconds (default: 90 seconds)
REQUEST_TIMEOUT_MS=90000

# ── Context Management ──────────────────────────────────────
# Auto-compact context when it fills up
AUTO_COMPACT=true

# Keep this many recent messages intact during compaction
COMPACT_KEEP_RECENT=20

# Lines of session notes and timeline to inject
SESSION_NOTES_LINES=50
TIMELINE_LINES=20

# ── AutoQA ──────────────────────────────────────────────────
AUTO_QA=true
AUTO_QA_LINT=true
AUTO_QA_TYPES=true
AUTO_QA_TESTS=false

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_TOKENS=20
RATE_LIMIT_REFILL=4
MESSAGE_QUEUE_SIZE=3

# ── Chat Mode ───────────────────────────────────────────────
# Default mode: auto | plan | ask | pm
CHAT_MODE=auto

# ── Parallel Agents ─────────────────────────────────────────
# Maximum concurrent agent sessions
MAX_PARALLEL_AGENTS=3

# ── Custom Instructions ─────────────────────────────────────
# Always-on instructions injected into every prompt (max 4000 chars)
CUSTOM_INSTRUCTIONS=

# Project-specific memory context
PROJECT_MEMORY=
