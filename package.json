{
  "name": "@twitchyvr/overlord",
  "version": "1.2.0",
  "description": "OVERLORD Web — AI orchestration platform with multi-agent coding assistant",
  "license": "AGPL-3.0",
  "main": "launcher.js",
  "bin": {
    "overlord": "launcher.js"
  },
  "files": [
    "launcher.js",
    "server.js",
    "hub.js",
    "modules/",
    "public/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node launcher.js",
    "dev": "node launcher.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run test",
    "check:ci": "npm run lint -- --max-warnings=0 && npm run test -- --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.3.1",
    "exif-parser": "^0.1.12",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer-core": "^24.37.5",
    "socket.io": "^4.7.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "semi": [
        "error",
        "always"
      ],
      "quotes": [
        "error",
        "single"
      ]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "modules/token-manager-module.js",
      "modules/config-module.js",
      "modules/character-normalization.js",
      "modules/markdown-module.js",
      "modules/context-tracker-module.js",
      "modules/conversation-module.js",
      "modules/skills-module.js",
      "modules/guardrail-module.js",
      "modules/notes-module.js",
      "!modules/**/*.bak"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 15,
        "functions": 20,
        "lines": 25,
        "statements": 25
      }
    }
  }
}
